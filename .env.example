#!/usr/bin/env bash

# Local agent marketplace toggles (see .agents/plugins/env-variables)
# Template for .envrc.local (gitignored). Copy to .envrc.local to override committed .env defaults.
# With direnv, root .envrc loads .env first, then .envrc.local when present (local overrides).
# When true, postinstall creates/updates .claude-plugin/marketplace.json and .claude/settings.json (Claude).
# When false, script removes only those fields (clean slate).
export ENABLE_LOCAL_AGENT_CLAUDE=false
# Optional: comma-separated plugin dir names to exclude from Claude marketplace (only when ENABLE_LOCAL_AGENT_CLAUDE=true). When false, this is ignored; safe to keep.
# export ENABLE_LOCAL_AGENT_CLAUDE=true CLAUDE_EXCLUDED_PLUGINS=env-variables,turborepo
export ENABLE_LOCAL_AGENT_CURSOR=false
# Optional: comma-separated plugin dir names to exclude from Cursor sync (only when ENABLE_LOCAL_AGENT_CURSOR=true). When false, this is ignored; safe to keep.
# export ENABLE_LOCAL_AGENT_CURSOR=true CURSOR_EXCLUDED_PLUGINS=env-variables,turborepo
